{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.AspNetCore.Hosting.Diagnostics": "Information"
    }
  },
  "AllowedHosts": "*",
  "WkApi": {
    "ApiKey": "",
    "CorsAllowedOrigins": [],
    "RunMigrationsAtStartup": true
  },
  "FutureMatches": {
    "CacheFileRelativePath": "Apps/FutureMatches/Cache/future-matches.json",
    "HtmlPageCacheDirectoryRelativePath": "Apps/FutureMatches/Cache/future-matches-page-cache",
    "HtmlPageCacheTtlHours": 24,
    "HtmlPageCacheMainPageTtlHours": 4320,
    "RequestDelayMs": 2000,
    "Games": [
      {
        "Id": "counterstrike",
        "FollowTeamIds": [ "Team_Vitality", "3DMAX" ]
      },
      {
        "Id": "leagueoflegends",
        "FollowTeamIds": [ "Karmine_Corp" ]
      },
      {
        "Id": "valorant",
        "FollowTeamIds": [ "Karmine_Corp" ]
      },
      {
        "Id": "rocketleague",
        "FollowTeamIds": [ "Karmine_Corp" ]
      }
    ]
  }
}
